generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  super_admin
  admin
  customer
}

enum BillingStatus {
  inactive
  checkout_pending
  active
  past_due
  canceled
}

enum ProjectStatus {
  draft
  active
  billing_enabled
  archived
}

enum OfferingType {
  stay
  product
  service
  event
}

enum OfferingStatus {
  draft
  scheduled
  active
  completed
  cancelled
  archived
}

enum BookingStatus {
  pending
  payment_pending
  partially_paid
  paid
  health_form_pending
  ready
  completed
  cancelled
  payment_failed
  refunded
}

enum PaymentMode {
  full
  split_2x
}

enum CompanionType {
  with_yoga
  without_yoga
}

enum HealthQuestionnaireStatus {
  not_started
  in_progress
  submitted
}

enum SatisfactionSurveyStatus {
  pending
  sent
  submitted
}

enum WorkspaceStatus {
  active
  suspended
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          UserRole  @default(customer)

  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  workspaceId   String?
  workspace     Workspace? @relation("WorkspaceOwner")

  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]  @relation("CustomerBookings")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String?
  status      ProjectStatus    @default(draft)

  admins      User[]
  settings    ProjectSettings?
  billing     ProjectBilling?
  offerings   Offering[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Workspace {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  ownerId     String            @unique
  owner       User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  status      WorkspaceStatus   @default(active)
  settings    WorkspaceSettings?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model WorkspaceSettings {
  id              String    @id @default(cuid())
  workspaceId     String    @unique
  siteName        String?
  primaryColor    String    @default("#6366f1")
  logoUrl         String?
  stripeAccountId String?
  stripeOnboarded Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ProjectSettings {
  id                    String   @id @default(cuid())
  projectId             String   @unique

  siteName              String?
  siteUrl               String?
  brandingPrimaryColor  String?
  brandingLogoUrl       String?

  billingEnabled        Boolean  @default(false)
  customerPortalEnabled Boolean  @default(true)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectBilling {
  id                   String        @id @default(cuid())
  projectId            String        @unique
  stripeCustomerId     String?       @unique
  stripeSubscriptionId String?       @unique
  stripePriceId        String?
  status               BillingStatus @default(inactive)
  currentPeriodEnd     DateTime?
  lastWebhookEventAt   DateTime?

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Offering {
  id          String         @id @default(cuid())
  projectId   String
  slug        String
  title       String
  description String?
  offeringType OfferingType
  startDate   DateTime
  endDate     DateTime
  location    String
  status      OfferingStatus @default(draft)
  isBookable  Boolean        @default(false)

  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roomOptions RoomOption[]
  bookings    Booking[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([projectId, slug])
  @@index([projectId, status])
  @@index([projectId, offeringType])
}

model RoomOption {
  id                        String    @id @default(cuid())
  offeringId                String
  name                      String
  slug                      String
  description               String?
  capacity                  Int       @default(1)
  basePrice                 Decimal
  currency                  String    @default("EUR")
  includedMainGuest         Boolean   @default(true)
  companionYogaSurcharge    Decimal   @default(0)
  companionNoYogaSurcharge  Decimal   @default(0)
  inventory                 Int       @default(1)
  isActive                  Boolean   @default(true)

  offering                  Offering  @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  bookings                  Booking[]

  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@unique([offeringId, slug])
  @@index([offeringId, isActive])
}

model Booking {
  id                      String       @id @default(cuid())
  bookingReference        String       @unique
  offeringId              String
  roomId                  String
  customerUserId          String?
  status                  BookingStatus @default(pending)
  paymentMode             PaymentMode   @default(full)
  currency                String
  roomBasePrice           Decimal
  hasCompanion            Boolean       @default(false)
  companionType           CompanionType?
  companionSurcharge      Decimal       @default(0)
  totalAmount             Decimal
  firstInstallmentAmount  Decimal
  secondInstallmentAmount Decimal       @default(0)
  secondInstallmentDueDate DateTime?
  amountPaid              Decimal       @default(0)
  amountRemaining         Decimal
  stripeCheckoutSessionId String?       @unique
  stripePaymentIntentId   String?       @unique
  stripeCustomerId        String?
  bookedAt                DateTime      @default(now())

  offering                Offering      @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  room                    RoomOption    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  customerUser            User?         @relation("CustomerBookings", fields: [customerUserId], references: [id], onDelete: SetNull)
  mainTraveler            MainTraveler?
  companionTraveler       CompanionTraveler?
  healthQuestionnaire     HealthQuestionnaire?
  satisfactionSurvey      SatisfactionSurvey?

  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([offeringId, status])
  @@index([roomId, status])
  @@index([customerUserId])
}

model MainTraveler {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  firstName    String
  lastName     String
  email        String
  phone        String
  addressLine1 String
  addressLine2 String?
  postalCode   String
  city         String
  country      String

  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CompanionTraveler {
  id                   String   @id @default(cuid())
  bookingId            String   @unique
  firstName            String
  lastName             String
  email                String
  phone                String
  participatesInYoga   Boolean

  booking              Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model HealthQuestionnaire {
  id                    String                    @id @default(cuid())
  bookingId             String                    @unique
  status                HealthQuestionnaireStatus @default(not_started)
  submittedAt           DateTime?
  consentAccepted       Boolean                   @default(false)
  emergencyContactName  String?
  emergencyContactPhone String?
  allergies             String?
  medicalConditions     String?
  currentMedications    String?
  mobilityLimitations   String?
  additionalNotes       String?
  accessTokenHash       String?
  accessExpiresAt       DateTime?
  lastAccessedAt        DateTime?
  submittedIpHash       String?

  booking               Booking                   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
}

model SatisfactionSurvey {
  id                String                   @id @default(cuid())
  bookingId         String                   @unique
  status            SatisfactionSurveyStatus @default(pending)
  sentAt            DateTime?
  submittedAt       DateTime?
  rating            Int?
  comment           String?
  wouldRecommend    Boolean?
  testimonialConsent Boolean                 @default(false)
  accessTokenHash   String?
  accessExpiresAt   DateTime?
  lastAccessedAt    DateTime?

  booking           Booking                  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
}
